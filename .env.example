# ============================================================
# Delivery Tracking Service — Environment Configuration
# ============================================================
# Usage: cp .env.example .env  — then fill in every blank field.
# NEVER commit .env to source control (it contains secrets).
#
# Requirements: SEC-REQ-045–046, DEPLOY-REQ-048
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
# Used by the postgres service and by the api service (DATABASE_URL must match).

POSTGRES_USER=delivery_user
POSTGRES_PASSWORD=                    # REQUIRED — choose a strong, unique password

POSTGRES_DB=delivery_tracker

# Async PostgreSQL URL consumed by SQLAlchemy (postgresql+psycopg driver).
# Keep in sync with POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above.
DATABASE_URL=postgresql+psycopg://delivery_user:CHANGE_ME@postgres:5432/delivery_tracker


# ── Parcel API ────────────────────────────────────────────────────────────────
# Obtain your key at https://web.parcelapp.net/account
# Rate limit: 20 requests / hour.
#   At the default 15-min interval (~4 req/hr used) you have ~16 req/hr margin.
#   Minimum supported interval: 5 minutes (lower values are clamped — POLL-REQ-005).
# 1Password: nexus > Parcel App API (field: API Key)

PARCEL_API_KEY=                       # REQUIRED — never share or commit this value


# ── Authentication ────────────────────────────────────────────────────────────
# Generate a secret with ONE of:
#   openssl rand -hex 32
#   python -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 characters enforced at startup (SEC-REQ-010).
# Changing this value invalidates all currently active sessions.
# 1Password: nexus > Delivery Tracking JWT (field: Secret Key)

JWT_SECRET_KEY=                       # REQUIRED — minimum 32 characters (SEC-REQ-010)

# JWT_ALGORITHM=HS256                 # Do not change — only HS256 is supported
# ACCESS_TOKEN_EXPIRE_MINUTES=60      # Valid range: 5–1440 minutes (default: 60)
# REFRESH_TOKEN_EXPIRE_DAYS=7         # Valid range: 1–30 days (default: 7)
# BCRYPT_ROUNDS=12                    # Valid range: 10–15. Higher = slower login, more secure (default: 12)
# COOKIE_SECURE=false                 # Set true when HTTPS_ENABLED=true (SEC-REQ-023)
# TRUST_PROXY_HEADERS=true            # Must be true when behind Nginx — enables real client IP for rate limiting


# ── First-Run Admin Setup ─────────────────────────────────────────────────────
# ADMIN_USERNAME and ADMIN_PASSWORD are used ONLY when the users table is empty
# (i.e., the very first container start after a fresh database).
# The seed script checks for an existing user before doing anything (idempotent).
#
# !! IMPORTANT !! Remove ADMIN_PASSWORD from .env after the first successful
#                 container start. The application logs a WARNING reminding you.
#                 Leaving it set is a security risk (SEC-REQ-004).
# 1Password: nexus > Delivery Tracking Admin (field: Password)

ADMIN_USERNAME=admin
ADMIN_PASSWORD=                       # REQUIRED for first run — min 12 chars; REMOVE AFTER SEEDING


# ── Polling ───────────────────────────────────────────────────────────────────
# Parcel API allows 20 req/hr. Default 15-min interval uses ~4 req/hr.
# Values below 5 minutes are clamped at startup — no hard failure (POLL-REQ-005).
# A cold start (empty DB) fires an immediate poll before the scheduler begins.

# POLL_INTERVAL_MINUTES=15            # Valid range: 5–60 recommended (default: 15)
# POLL_JITTER_SECONDS=30              # Random ±N seconds added per poll. Range: 0–120 (default: 30)
# POLL_HTTP_TIMEOUT_SECONDS=30        # Per-request HTTP timeout. Range: 5–120 seconds (default: 30)
# POLL_MAX_RETRIES=3                  # Network retries on failure. Range: 0–5 (default: 3)


# ── Security ──────────────────────────────────────────────────────────────────
# COOKIE_SECURE and HTTPS_ENABLED should always be changed together.
# When HTTPS_ENABLED=true but COOKIE_SECURE=false the application logs a warning
# at startup (SEC-REQ-044).

HTTPS_ENABLED=false                   # Set true when using nginx-https.conf + TLS certificates

# SSL certificate paths are mounted into the frontend container at runtime.
# Required only when HTTPS_ENABLED=true:
# SSL_CERT_PATH=/path/on/host/fullchain.pem
# SSL_KEY_PATH=/path/on/host/privkey.pem


# ── Application ───────────────────────────────────────────────────────────────
# 'development' enables CORS for localhost origins and OpenAPI docs at /api/docs.
# Always use 'production' in deployed environments.
ENVIRONMENT=production

# LOG_LEVEL=INFO                      # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
# VERSION=1.0.0                       # Application version string (app-managed; override for custom builds)


# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_HTTP_PORT=80                 # Host port for the web dashboard (maps to container port 80)


# ── Demo Mode ────────────────────────────────────────────────────────────────
# When true: seeds a demo user (demo/demo) with fixture deliveries instead of
# an admin user. Disables Parcel API polling. PARCEL_API_KEY is not required.
# Used for the day1.edwardhallam.com showcase deployment.

DEMO_MODE=false
